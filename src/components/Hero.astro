---
// Hero section
---

<section id="hero">
  <!-- Circuit board background -->
  <svg class="circuit-bg" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" aria-hidden="true">
    <defs>
      <pattern id="circuit" x="0" y="0" width="220" height="220" patternUnits="userSpaceOnUse">

        <!-- ── Traces ── -->
        <!-- Horizontal -->
        <line x1="0"   y1="48"  x2="65"  y2="48"  stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="105" y1="48"  x2="220" y2="48"  stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="0"   y1="140" x2="55"  y2="140" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="95"  y1="140" x2="160" y2="140" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="165" y1="105" x2="220" y2="105" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="0"   y1="195" x2="55"  y2="195" stroke="rgba(96,165,250,.15)" stroke-width="1.5"/>

        <!-- Vertical -->
        <line x1="65"  y1="0"   x2="65"  y2="48"  stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="65"  y1="48"  x2="65"  y2="88"  stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="105" y1="0"   x2="105" y2="48"  stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="105" y1="88"  x2="105" y2="140" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="55"  y1="140" x2="55"  y2="220" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="160" y1="105" x2="160" y2="140" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="160" y1="140" x2="160" y2="220" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <line x1="55"  y1="0"   x2="55"  y2="48"  stroke="rgba(96,165,250,.15)" stroke-width="1.5"/>

        <!-- L-bend paths -->
        <path d="M65,88 L85,88 L85,140"  fill="none" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <path d="M85,140 L95,140"         fill="none" stroke="rgba(59,130,246,.22)" stroke-width="1.5"/>
        <path d="M165,105 L165,48"        fill="none" stroke="rgba(96,165,250,.15)" stroke-width="1.5" stroke-dasharray="4 3"/>
        <path d="M55,195 L55,140"         fill="none" stroke="rgba(96,165,250,.15)" stroke-width="1.5"/>

        <!-- ── Vias (junction circles) ── -->
        <!-- Standard blue vias -->
        <circle cx="65"  cy="48"  r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(96,165,250,.55)" stroke-width="1.5"/>
        <circle cx="65"  cy="48"  r="1.8" fill="rgba(96,165,250,.7)"/>

        <circle cx="105" cy="48"  r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(96,165,250,.55)" stroke-width="1.5"/>
        <circle cx="105" cy="48"  r="1.8" fill="rgba(96,165,250,.7)"/>

        <circle cx="85"  cy="140" r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(96,165,250,.55)" stroke-width="1.5"/>
        <circle cx="85"  cy="140" r="1.8" fill="rgba(96,165,250,.7)"/>

        <circle cx="55"  cy="140" r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(96,165,250,.55)" stroke-width="1.5"/>
        <circle cx="55"  cy="140" r="1.8" fill="rgba(96,165,250,.7)"/>

        <circle cx="160" cy="140" r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(96,165,250,.55)" stroke-width="1.5"/>
        <circle cx="160" cy="140" r="1.8" fill="rgba(96,165,250,.7)"/>

        <!-- Cyan accent vias -->
        <circle cx="160" cy="105" r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(6,182,212,.6)"   stroke-width="1.5"/>
        <circle cx="160" cy="105" r="1.8" fill="rgba(6,182,212,.75)"/>

        <circle cx="55"  cy="195" r="4.5" fill="rgba(3,7,18,.95)"   stroke="rgba(6,182,212,.6)"   stroke-width="1.5"/>
        <circle cx="55"  cy="195" r="1.8" fill="rgba(6,182,212,.75)"/>

        <!-- ── Component pads / silkscreen ── -->
        <!-- Small IC outline -->
        <rect x="108" y="38" width="22" height="18" rx="2"
              fill="none" stroke="rgba(59,130,246,.18)" stroke-width="1"/>
        <!-- IC pin markers -->
        <line x1="108" y1="43" x2="104" y2="43" stroke="rgba(59,130,246,.18)" stroke-width="1"/>
        <line x1="108" y1="49" x2="104" y2="49" stroke="rgba(59,130,246,.18)" stroke-width="1"/>
        <line x1="130" y1="43" x2="134" y2="43" stroke="rgba(59,130,246,.18)" stroke-width="1"/>
        <line x1="130" y1="49" x2="134" y2="49" stroke="rgba(59,130,246,.18)" stroke-width="1"/>

        <!-- SMD resistor -->
        <rect x="68" y="132" width="14" height="7" rx="1.5"
              fill="rgba(59,130,246,.1)" stroke="rgba(59,130,246,.2)" stroke-width="1"/>

        <!-- SMD capacitor -->
        <rect x="150" y="98" width="8" height="14" rx="1.5"
              fill="rgba(6,182,212,.08)" stroke="rgba(6,182,212,.22)" stroke-width="1"/>

        <!-- Pin 1 dot on IC -->
        <circle cx="111" cy="42" r="1.2" fill="rgba(59,130,246,.3)"/>

      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#circuit)"/>
  </svg>
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>

  <div class="hero-inner">
    <div class="hero-badge">
      <span class="dot"></span>
      Technology Solutions for Home &amp; Business
    </div>

    <img src="/hero-heading.png" alt="Technology Made Simple" class="hero-heading-img" />

    <p class="hero-sub">
      Expert help with hardware, networking, home storage, domains and websites -
      reliable, jargon-free and catered around your needs.
    </p>

    <div class="btn-row">
      <button class="btn-primary" onclick="document.getElementById('services')?.scrollIntoView({behavior:'smooth'})">
        View Services
      </button>
      <button class="btn-ghost" onclick="document.getElementById('contact')?.scrollIntoView({behavior:'smooth'})">
        Contact Us →
      </button>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  section {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    background: var(--bg);
    padding-top: 80px;
  }
  .circuit-bg {
    position: absolute; inset: 0; pointer-events: none;
    opacity: .35;
  }
  .hero-blob {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none;
  }
  .hero-blob-1 {
    top: 25%; left: 15%; width: 500px; height: 500px;
    background: rgba(59,130,246,.15);
  }
  .hero-blob-2 {
    bottom: 20%; right: 15%; width: 350px; height: 350px;
    background: rgba(6,182,212,.1);
  }
  .hero-inner {
    position: relative; z-index: 1;
    text-align: center; max-width: 860px; margin: 0 auto;
    padding: 0 24px;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(30,41,59,.8);
    border: 1px solid rgba(59,130,246,.3);
    color: var(--blue-lt); font-size: .85rem; font-weight: 500;
    padding: 8px 18px; border-radius: 99px; margin-bottom: 28px;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--blue-lt);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900; line-height: 1.08;
    color: var(--text); margin-bottom: 24px; letter-spacing: -.02em;
  }
  .grad {
    background: linear-gradient(135deg, var(--blue-lt), var(--cyan));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-heading-img {
    max-width: 100%; width: 680px; height: auto;
    display: block; margin: 0 auto 24px;
  }
  .hero-sub {
    font-size: 1.2rem; color: var(--muted);
    max-width: 580px; margin: 0 auto 40px; line-height: 1.75;
  }
  .btn-row {
    display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
  }
  .scroll-hint {
    position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: var(--faint); font-size: .7rem; letter-spacing: .12em; text-transform: uppercase;
  }
  .scroll-hint svg { animation: bounce 2s ease-in-out infinite; }
  @keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(4px)} }
</style>
