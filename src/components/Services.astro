---
const services = [
  {
    title: 'Hardware Installation',
    desc: 'PC builds, component upgrades, peripheral setup, and hardware troubleshooting for home and office environments.',
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
  },
  {
    title: 'UniFi Router & Network Setup',
    desc: 'Professional Ubiquiti UniFi design and installation — access points, switches, security gateways, and VLANs configured for your space.',
    icon: `<path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/>`,
  },
  {
    title: 'Domain Setup & Management',
    desc: 'Domain registration, DNS configuration, transfers, and everything needed to own and control your online identity.',
    icon: `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  },
  {
    title: 'Cloudflare & ProtonMail',
    desc: 'Cloudflare DNS, CDN, and security configuration. ProtonMail custom domain setup for secure, professional email.',
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: 'Website Setup & Hosting',
    desc: 'Help choosing a platform, configuring hosting, and connecting your custom domain to get your site live quickly.',
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
  },
];
---

<section id="services">
  <div class="container">
    <div class="text-center reveal">
      <p class="section-eyebrow">What We Do</p>
      <h2 class="section-title">Our Services</h2>
      <p class="section-sub">Practical technology support, handled professionally from start to finish.</p>
    </div>

    <div class="services-grid reveal">
      {services.map(s => (
        <div class="service-card">
          <div class="service-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"
                 set:html={s.icon} />
          </div>
          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>
        </div>
      ))}

      <!-- CTA card -->
      <div class="cta-card">
        <div>
          <h3 class="cta-title">Not sure what you need?</h3>
          <p class="cta-body">Describe your problem and we'll figure it out together — no jargon, no pressure.</p>
        </div>
        <button class="cta-btn" onclick="document.getElementById('contact')?.scrollIntoView({behavior:'smooth'})">
          Talk to Us →
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  section { background: var(--bg); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px; margin-top: 56px;
  }
  .service-card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 32px;
    transition: border-color .2s, background .2s;
  }
  .service-card:hover {
    border-color: rgba(59,130,246,.5);
    background: rgba(30,41,59,.6);
  }
  .service-icon {
    width: 52px; height: 52px; border-radius: 12px;
    background: rgba(30,58,138,.4);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px; color: var(--blue-lt);
    transition: background .2s;
  }
  .service-card:hover .service-icon { background: rgba(30,58,138,.7); }
  .service-title { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: 10px; }
  .service-desc  { font-size: .875rem; color: var(--muted); line-height: 1.75; }

  .cta-card {
    background: linear-gradient(135deg, #1d4ed8, #0891b2);
    border-radius: var(--radius); padding: 32px;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .cta-title { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 10px; }
  .cta-body  { font-size: .875rem; color: rgba(255,255,255,.8); line-height: 1.75; }
  .cta-btn {
    display: inline-block; margin-top: 24px;
    background: #fff; color: #1d4ed8;
    padding: 10px 20px; border-radius: 10px;
    font-size: .875rem; font-weight: 700; border: none; cursor: pointer;
    transition: background .2s; align-self: flex-start;
  }
  .cta-btn:hover { background: #eff6ff; }

  @media (max-width: 900px) { .services-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .services-grid { grid-template-columns: 1fr; } }
</style>
